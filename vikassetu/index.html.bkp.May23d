<body>

    <!-- HERO -->

    <header class="hero">

        <div class="hero-content">

            <div class="badge">
                Official WhatsApp Communication Initiative • Soochna Mandir
            </div>

            <h1 class="main-title">
                Vikas Setu
            </h1>

            <p class="subtitle">
                Official WhatsApp-based communication and citizen support initiative.
            </p>

            <p class="hero-description">
                Vikas Setu enables WhatsApp-based public interaction,
                communication support, citizen assistance, and accessible
                civic information services operated under Soochna Mandir.
            </p>

        </div>

    </header>

    <!-- ABOUT -->

    <section class="about-section">

        <h2>About Vikas Setu</h2>

        <p>
            Vikas Setu is an independent communication initiative operated
            under Soochna Mandir.
        </p>

        <p>
            The initiative focuses on enabling communication support,
            public accessibility, and community-oriented assistance through
            digital systems and WhatsApp-based interaction.
        </p>

        <p>
            Vikas Setu is not affiliated with government agencies.
        </p>

    </section>

    <!-- WHATSAPP COMMUNICATION -->

    <section class="content-section">

        <h2>WhatsApp-Based Communication</h2>

        <div class="card-grid">

