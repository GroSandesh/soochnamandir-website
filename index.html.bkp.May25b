            color: #18181b;
            overflow-x: hidden;
        }

        .serif {
            font-family: Georgia, "Times New Roman", serif;
        }

        .grain::before {
            content: "";
            position: fixed;
            inset: 0;
            opacity: 0.04;
            pointer-events: none;
            background-image:
                radial-gradient(#000 0.5px, transparent 0.5px);
            background-size: 8px 8px;
        }

        .parallax {
            transform: translateY(var(--parallax-offset, 0px));
            transition: transform 0.1s linear;
        }

    </style>

</head>

<body class="grain">

